rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isAuth() && getUserData().isActive == true;
    }

    function hasPermission(perm) {
      return isActive() && getUserData().permissions[perm] == true;
    }

    function isMaster() {
      return isActive() && getUserData().role == 'master';
    }

    // ─── Users (full profile — master manages, user reads own) ───
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isMaster());
      allow create: if isMaster();
      allow update: if isAuth() && (
        request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin'])
        || isMaster()
      );
      allow delete: if false;
    }

    // ─── Sales Records ───
    match /sales_records/{docId} {
      // אבטחה (F4): קריאה מצומצמת להרשאות תפעוליות (היה isActive = כל עובד פעיל).
      // כל הקוראים מכוסים: מכירות (salesManagement), בילינג+גבייה (billingManagement),
      // העשרת ליד (leadsManagement), השלמה-אוטומטית בטופס (salesForm). הגשר ל-law-office-system
      // קורא דרך Admin SDK (service account) → עוקף rules → לא מושפע.
      allow read: if hasPermission('salesManagement') || hasPermission('billingManagement') || hasPermission('leadsManagement') || hasPermission('salesForm') || isMaster();
      // הנה"ח (billingManagement, ללא salesForm) יוצר רשומת-מכר בסימון תשלום (payments.js:460/861) — היה נדחה ונבלע בשקט.
      allow create: if hasPermission('salesForm') || hasPermission('billingManagement');
      allow update: if hasPermission('salesForm');
      allow delete: if isMaster();
    }

    // ─── Recurring Billing ───
    match /recurring_billing/{docId} {
      allow read: if hasPermission('billingManagement') || isMaster();
      allow create: if hasPermission('billingManagement');
      allow update: if hasPermission('billingManagement');
      allow delete: if isMaster();

      match /payments/{paymentId} {
        allow read: if hasPermission('billingManagement') || isMaster();
        allow create: if hasPermission('billingManagement');
        allow update: if hasPermission('billingManagement');
        allow delete: if hasPermission('billingManagement');
      }
    }

    // ─── Audit Log ───
    match /audit_log/{docId} {
      allow create: if isAuth();
      allow read: if hasPermission('activityLog');
      allow update: if false;
      allow delete: if false;
    }

    // ─── Leads CRM ───
    // F3 סגור (2026-06-17): יצירת לידים = Admin SDK / service-account בלבד (עוקף rules) —
    // netlify/functions/lead-intake.js (קמפיינים) + lead-from-email.js (מייל) + בוט WhatsApp. הקליינט אינו יוצר לידים.
    match /leads/{docId} {
      // אבטחה (F2): קריאה מצומצמת ל-leadsManagement/salesManagement (היה isActive = כל עובד פעיל).
      // תואם לכפתור הניווט (navigation.js:156 — leadsManagement || salesManagement || master),
      // כך שאף תפקיד שמגיע למסך הלידים לא נשבר (כולל הנה"ח שמחזיק salesManagement).
      allow read: if hasPermission('leadsManagement') || hasPermission('salesManagement') || isMaster();
      allow create: if false;  // F3: world-writable נסגר — רק Admin SDK יוצר (עוקף rules)
      allow update: if isActive();
      allow delete: if isMaster();
    }

    // ─── Clients (central client identity) ───
    match /clients/{docId} {
      // אבטחה (F5): read/create/update מצומצמים להרשאות שנוגעות בלקוחות (היה isActive = כל עובד פעיל).
      // קוראים: autocomplete בטופס (salesForm) + getOrCreateClient מטופס/בילינג (salesForm/billingManagement).
      // כותבים: getOrCreateClient (salesForm/billingManagement/salesManagement), עריכת בילינג (billing.js:1609),
      // עריכת מכירה (sales-records.js:750). הבוט כותב clients דרך Admin SDK → עוקף rules → לא מושפע.
      allow read: if hasPermission('salesForm') || hasPermission('salesManagement') || hasPermission('billingManagement') || isMaster();
      allow create: if hasPermission('salesForm') || hasPermission('salesManagement') || hasPermission('billingManagement') || isMaster();
      allow update: if hasPermission('salesForm') || hasPermission('salesManagement') || hasPermission('billingManagement') || isMaster();
      allow delete: if isMaster();
    }

    // ─── Decrypt Rate Limiting ───
    match /decrypt_rate_limit/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ─── Bot Status (public read for status page, write by admin SDK only) ───
    match /bot_status/{docId} {
      allow read: if true;
      allow write: if false;

      match /daily_stats/{dateId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ─── Deny everything else (including deprecated public_users) ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
