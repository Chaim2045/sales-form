# WhatsApp Bot Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (for Claude parsing)
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK — path to service account JSON file
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# WhatsApp group name to monitor (exact name as it appears in WhatsApp)
WHATSAPP_GROUP_NAME=דיווחי עסקאות

# Google Sheets webhook URL (optional — same as in env-config.js)
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/.../exec

# Bot operator phone number (for sending private conversation)
# Format: 972XXXXXXXXX (no +, no leading 0)
# Leave empty to reply in the group itself
BOT_OPERATOR_PHONE=

# Default attorney name (who the bot logs records under)
DEFAULT_ATTORNEY=עו"ד גיא הרשקוביץ

# Default branch
DEFAULT_BRANCH=תל אביב
